// Example: multiple dam types affecting downstream flow
let rain_today = rain(40mm);
let inflow = 100;

dam r1 = reduce(0.7);               // 70% passes through
dam c1 = cap(50);                   // caps outflow at 50
dam b1 = boost(0.25);               // adds 25% of rain_today
dam t1 = threshold(60, 0.4, 0.9);   // low=0.4, high=0.9
level t1 = 55;                      // below threshold → low factor

inflow -> r1;
r1 -> c1;
c1 -> b1;
b1 -> t1;

output t1;
