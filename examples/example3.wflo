dam d1 = 0.8;                  // implicit reduce
dam d2 = reduce(0.7);          // explicit reduce
dam d3 = cap(50);              // cap at maximum
dam d4 = boost(0.25);          // boost inflow by 25% of rain_today
dam d5 = threshold(50, 0.3, 0.9);  // factor depends on dam level
level d5 = 40;                 // below threshold
output d5;
