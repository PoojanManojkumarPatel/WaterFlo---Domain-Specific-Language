// Example 2: base inflow capped, then boosted by rainfall

let rain_today = rain(20mm);   // 20 units of rain
let base = 30;                 // base inflow from some upstream system

dam c = cap(40);               // c will never output more than 40
dam b = boost(0.5);            // b adds 0.5 * rain_today to its inflow

base -> c;
c -> b;

output b;
